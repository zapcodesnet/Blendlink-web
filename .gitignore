**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/
frontend/node_modules/.cache/

# Local development files only (NOT base .env files)
*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# IMPORTANT: Base .env files (frontend/.env, backend/.env, mobile/.env) are NOT ignored
# They are REQUIRED for Emergent deployment - do not add *.env to this file
frontend/node_modules/.cache/default-development/0.pack
-e 
